---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import PostCard from "@components/PostCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getPostUrlBySlug } from "../utils/url-utils";
import { getPostsByCategory } from "../utils/content-utils";

const entry = await getEntry("spec", "paper-notes");
if (!entry) throw new Error("Paper Notes page content not found");
const { Content } = await render(entry);

const paperNotesPosts = await getPostsByCategory("Paper Notes");
let delay = 0;
const interval = 50;
---
<MainGridLayout title="Paper Notes" description="Reading notes on research papers">
	<div class="flex w-full flex-col gap-4">
		<div class="rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
			<div class="card-base z-10 px-9 py-6 relative w-full">
				<Markdown class="mt-2">
					<Content />
				</Markdown>
			</div>
		</div>

		{paperNotesPosts.length > 0 && (
			<div class="transition flex flex-col rounded-[var(--radius-large)] md:gap-4">
				<h2 class="font-bold text-xl mb-2 px-1">Articles</h2>
				{paperNotesPosts.map((post) => (
					<PostCard
						entry={post}
						title={post.data.title}
						tags={post.data.tags}
						category={post.data.category}
						published={post.data.published}
						updated={post.data.updated}
						url={getPostUrlBySlug(post.slug)}
						image={post.data.image}
						description={post.data.description}
						draft={post.data.draft}
						class:list="onload-animation"
						style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
					/>
				))}
			</div>
		)}
	</div>
</MainGridLayout>
